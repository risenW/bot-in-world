# large source splat artifacts — regenerate via scripts/fetch-world.sh + splat-transform.
# The deployable .sog (compressed splat) and the two demo worlds' collision meshes
# ARE committed so the GitHub Pages build has playable scenes out of the box.
public/levels/**/*.ply
public/levels/**/*.spz
!public/levels/warehouse/mesh_simplified.ply
!public/levels/gallery/mesh_simplified.ply

# scratch
tmp/
.claude/
