{
  "name": "spaitial-bot",
  "version": "0.1.0",
  "description": "SpAItial Bot — a humanoid bot learns to navigate worlds generated by the Spaitial API, in your browser. PlayCanvas + Rapier + a TypeScript port of PufferLib's PPO.",
  "type": "module",
  "license": "MIT",
  "author": "https://github.com/risenW",
  "repository": "https://github.com/risenW/spaitial-bot",
  "homepage": "https://github.com/risenW/spaitial-bot",
  "bugs": "https://github.com/risenW/spaitial-bot/issues",
  "keywords": [
    "spaitial",
    "bot",
    "rl",
    "navigation"
  ],
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "bake": "tsx scripts/bake-navgrid.ts",
    "pretrain": "tsx scripts/pretrain.ts"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "latest",
    "playcanvas": "latest"
  },
  "devDependencies": {
    "@playcanvas/splat-transform": "^2.5.2",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.4.2"
  }
}
